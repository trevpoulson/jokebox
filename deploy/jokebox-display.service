[Unit]
Description=Joke Box display power helper (real backlight off when app sleeps)
After=jokebox-server.service
Requires=jokebox-server.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/jokebox/software
ExecStart=/home/pi/jokebox/software/venv/bin/python pi_display.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
